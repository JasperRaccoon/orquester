# Copy to /var/lib/orquester/daemon/env/opencode.env (chmod 600, owned by the orquester user).
# Never commit the real file. OpenCode needs NO_PROXY for its local TUI server.
HTTPS_PROXY=http://proxy-user:proxy-password@proxy.example.com:12323
HTTP_PROXY=http://proxy-user:proxy-password@proxy.example.com:12323
https_proxy=http://proxy-user:proxy-password@proxy.example.com:12323
http_proxy=http://proxy-user:proxy-password@proxy.example.com:12323
NO_PROXY=localhost,127.0.0.1,::1
no_proxy=localhost,127.0.0.1,::1
